{
  "name": "project-inventory",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cf": "asdf install nodejs 20.19.2 && asdf local nodejs 20.19.2 && opennextjs-cloudflare build && mkdir -p .open-next/worker && cp -r .open-next/assets/. .open-next/.build .open-next/cache .open-next/cloudflare .open-next/middleware .open-next/server-functions .open-next/worker/ && mv .open-next/worker.js .open-next/worker/_worker.js",
    "start": "next start",
    "start:cf": "opennextjs-cloudflare dev",
    "deploy:cf": "npm run build:cf && wrangler deploy",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:push:d1": "wrangler d1 execute project-inventory --local --file=drizzle/*.sql",
    "db:studio": "drizzle-kit studio",
    "db:seed": "npx tsx src/lib/db/seed.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@opennextjs/cloudflare": "^1.19.1",
    "bcryptjs": "^2.4.3",
    "date-fns": "^3.6.0",
    "drizzle-orm": "^0.31.2",
    "jose": "^5.6.3",
    "next": "15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuid": "^10.0.0",
    "wrangler": "^3.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.19",
    "drizzle-kit": "^0.22.8",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.3.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.15.2",
    "typescript": "^5.4.5"
  }
}
